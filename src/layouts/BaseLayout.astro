---
import "../styles/global.css";
const { title } = Astro.props;
const siteUrl = "https://sergeshub.github.io/sergeroberge-site";
const ogTitle = "Serge Roberge — Technology Executive";
const ogDescription =
  "Engineering leadership focused on stabilizing and scaling revenue-critical platforms while enabling continuous modernization.";
const ogImage = `${siteUrl}/og-image.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>

  <body>
    <main>
      <slot />
    </main>
  </body>
</html>